{
  "description": "session/configChanged merges new values into config.values",
  "reducer": "session",
  "initial": {
    "summary": {
      "resource": "copilot:/test",
      "provider": "copilot",
      "title": "Test",
      "status": 1,
      "createdAt": 1000,
      "modifiedAt": 2000
    },
    "config": {
      "schema": {
        "type": "object",
        "properties": {
          "useWorktree": { "type": "boolean", "title": "Use Worktree" },
          "baseBranch": { "type": "string", "title": "Base Branch" }
        }
      },
      "values": { "useWorktree": true, "baseBranch": "main" }
    },
    "lifecycle": "ready",
    "turns": []
  },
  "actions": [
    {
      "type": "session/configChanged",
      "session": "copilot:/test",
      "config": { "baseBranch": "develop" }
    }
  ],
  "expected": {
    "summary": {
      "resource": "copilot:/test",
      "provider": "copilot",
      "title": "Test",
      "status": 1,
      "createdAt": 1000,
      "modifiedAt": 9999
    },
    "config": {
      "schema": {
        "type": "object",
        "properties": {
          "useWorktree": { "type": "boolean", "title": "Use Worktree" },
          "baseBranch": { "type": "string", "title": "Base Branch" }
        }
      },
      "values": { "useWorktree": true, "baseBranch": "develop" }
    },
    "lifecycle": "ready",
    "turns": []
  }
}
