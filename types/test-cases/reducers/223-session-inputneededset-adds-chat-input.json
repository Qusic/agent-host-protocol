    },
    "lifecycle": "ready",
    "activeClients": [],
    "chats": [],
    "inputNeeded": [
      {
        "kind": "chatInput",
        "id": "copilot:/test-session/chat-1#req-1",
        "chat": "copilot:/test-session/chat-1",
        "request": {
          "id": "req-1",
          "message": "Which environment?",
          "questions": [
            {
              "kind": "single-select",
              "id": "env",
              "message": "Pick an environment",
              "options": [
                { "id": "dev", "label": "Dev" },
                { "id": "prod", "label": "Prod" }
              ]
            }
          ]
        }
      }
    ]
  }
}
