{
  "description": "changeset/statusChanged with error attaches the error payload",
  "reducer": "changeset",
  "initial": {
    "status": "computing",
    "files": []
  },
  "actions": [
    {
      "type": "changeset/statusChanged",
      "changeset": "copilot:/abc/changeset/session",
      "status": "error",
      "error": { "errorType": "git", "message": "fatal: not a git repository" }
    }
  ],
  "expected": {
    "status": "error",
    "error": { "errorType": "git", "message": "fatal: not a git repository" },
    "files": []
  }
}
